# AI Supply Chain Trust runtime settings.
# Copy to .env with `make setup`.

# Comma-separated origins allowed to call /api/v1 from web, extension, or client apps.
# Production fails closed if this is unset or '*'. Use explicit origins there.
AI_SUPPLY_CHAIN_TRUST_ALLOWED_ORIGINS=*
AI_SUPPLY_CHAIN_TRUST_ENV=

# Preferred short-lived scoped JWT auth for scheduler/admin callers.
AI_SUPPLY_CHAIN_TRUST_JWT_SECRET=
AI_SUPPLY_CHAIN_TRUST_JWT_ISSUER=ai-supply-chain-trust
AI_SUPPLY_CHAIN_TRUST_JWT_AUDIENCE=ai-supply-chain-trust

# Legacy shared secret for scheduler/admin endpoints. Prefer scoped JWTs above.
AI_SUPPLY_CHAIN_TRUST_SCHEDULER_TOKEN=

# GitHub webhook HMAC and replay protection.
AI_SUPPLY_CHAIN_TRUST_WEBHOOK_SECRET=
AI_SUPPLY_CHAIN_TRUST_WEBHOOK_REPLAY_WINDOW_SECONDS=300

# Break-glass discover bypass. Requires all three values; keep unset normally.
AI_SUPPLY_CHAIN_TRUST_ALLOW_UNAUTHENTICATED_DISCOVER=
AI_SUPPLY_CHAIN_TRUST_BREAK_GLASS=
AI_SUPPLY_CHAIN_TRUST_BREAK_GLASS_REASON=

# Optional runtime DB restore/backup URLs for Cloud Run scheduled discovery.
AI_SUPPLY_CHAIN_TRUST_DB_BACKEND=sqlite
AI_SUPPLY_CHAIN_TRUST_DATABASE_URL=
AI_SUPPLY_CHAIN_TRUST_DUAL_WRITE_SQLITE_PATH=
AI_SUPPLY_CHAIN_TRUST_DB_RESTORE_URL=
AI_SUPPLY_CHAIN_TRUST_DB_BACKUP_URL=
AI_SUPPLY_CHAIN_TRUST_DB_STORAGE_TOKEN=
AI_SUPPLY_CHAIN_TRUST_DB_STORAGE_TIMEOUT=60

# Optional demo data. Keep unset in production; set to 1 only for local demos/tests.
AI_SUPPLY_CHAIN_TRUST_ENABLE_SEED_DATA=

# Shared discovery cache TTL in seconds for multi-source scheduled discovery.
AI_SUPPLY_CHAIN_TRUST_DISCOVERY_CACHE_TTL=1800

# Scanner execution mode. Keep sync locally; set async when scanner workers are deployed.
AI_SUPPLY_CHAIN_TRUST_SCANNER_MODE=sync
AI_SUPPLY_CHAIN_TRUST_TASK_DISPATCHER=local
AI_SUPPLY_CHAIN_TRUST_TASK_DISPATCHER_URL=
AI_SUPPLY_CHAIN_TRUST_TASK_DISPATCHER_TIMEOUT=15
AI_SUPPLY_CHAIN_TRUST_CLOUD_TASKS_PROJECT=
AI_SUPPLY_CHAIN_TRUST_CLOUD_TASKS_LOCATION=
AI_SUPPLY_CHAIN_TRUST_CLOUD_TASKS_QUEUE=
AI_SUPPLY_CHAIN_TRUST_CLOUD_TASKS_WORKER_URL=
AI_SUPPLY_CHAIN_TRUST_CLOUD_TASKS_SERVICE_ACCOUNT=
AI_SUPPLY_CHAIN_TRUST_CLOUD_TASKS_TIMEOUT=15
AI_SUPPLY_CHAIN_TRUST_WORKER_TOKEN=
AI_SUPPLY_CHAIN_TRUST_ALERT_WEBHOOK_URL=
AI_SUPPLY_CHAIN_TRUST_FEEDBACK_WEBHOOK_URL=
OPENROUTER_API_KEY=
OPENROUTER_MODEL_PRIMARY=openai/gpt-4.1-mini
OPENROUTER_MODEL_SECONDARY=google/gemini-2.5-flash
OPENROUTER_REQUIRE_NON_FREE_MODEL=1
AI_SUPPLY_CHAIN_TRUST_FAILURE_RECOVERY_INTERVAL_SECONDS=600

# Rust runtime background daemon. Keep disabled unless this instance should mutate the queue.
AI_SUPPLY_CHAIN_TRUST_DAEMON=0
AI_SUPPLY_CHAIN_TRUST_DAEMON_QUEUE_INTERVAL=30
AI_SUPPLY_CHAIN_TRUST_DAEMON_DISCOVERY_INTERVAL=86400
AI_SUPPLY_CHAIN_TRUST_DAEMON_DISCOVER_LIMIT=10
AI_SUPPLY_CHAIN_TRUST_DAEMON_DISCOVER_DAYS=7
AI_SUPPLY_CHAIN_TRUST_DAEMON_DISCOVER_MIN_STARS=500
AI_SUPPLY_CHAIN_TRUST_DAEMON_MULTI_SOURCE=1
AI_SUPPLY_CHAIN_TRUST_DAEMON_MAX_CONCURRENT=2
AI_SUPPLY_CHAIN_TRUST_WORKER_START_DELAY_SECONDS=0
AI_SUPPLY_CHAIN_TRUST_FOREGROUND_TIMEOUT_SECONDS=5
AI_SUPPLY_CHAIN_TRUST_EVIDENCE_NVD_CONCURRENCY=2
AI_SUPPLY_CHAIN_TRUST_EVIDENCE_FINALIZE_CONCURRENCY=2
# GitHub requests reserved for foreground scans; background workers yield below this value.
AI_SUPPLY_CHAIN_TRUST_GITHUB_FOREGROUND_RESERVE=500

# Optional structured JSON access logs and worker correlation id.
AI_SUPPLY_CHAIN_TRUST_ACCESS_LOG=
AI_SUPPLY_CHAIN_TRUST_CORRELATION_ID=

# Optional event bus dual-publish. Use http for a Pub/Sub bridge or relay endpoint.
AI_SUPPLY_CHAIN_TRUST_EVENT_BUS=local
AI_SUPPLY_CHAIN_TRUST_EVENT_BUS_URL=
AI_SUPPLY_CHAIN_TRUST_EVENT_BUS_TOKEN=
AI_SUPPLY_CHAIN_TRUST_EVENT_BUS_TIMEOUT=10
AI_SUPPLY_CHAIN_TRUST_PUBSUB_PROJECT=
AI_SUPPLY_CHAIN_TRUST_PUBSUB_TOPIC=
AI_SUPPLY_CHAIN_TRUST_PUBSUB_TIMEOUT=10
AI_SUPPLY_CHAIN_TRUST_EVENT_RETAIN_HOURS=24
AI_SUPPLY_CHAIN_TRUST_EVENT_RETAIN_MIN=100000

# Optional direct REST auth override for Cloud Tasks/Pub/Sub. Cloud Run should normally use metadata credentials.
AI_SUPPLY_CHAIN_TRUST_GCP_ACCESS_TOKEN=
AI_SUPPLY_CHAIN_TRUST_GCP_METADATA_TIMEOUT=2

# Emergency-only CI override for secret expiry checks. Must be a future date.
AI_SUPPLY_CHAIN_TRUST_SECRET_EXPIRY_OVERRIDE_UNTIL=

# Optional tokens used by CLI fetch modes.
GITHUB_TOKEN=
GITHUB_AUTH_TOKEN=
# Raises NVD API capacity; sent only as the server-side `apiKey` header.
NVD_API_KEY=
HF_TOKEN=
HUGGINGFACE_TOKEN=
HUGGING_FACE_HUB_TOKEN=
